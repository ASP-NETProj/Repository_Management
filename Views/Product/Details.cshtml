@model RepositoryApp.Models.Product

@{
    ViewData["Title"] = "Product Details";
    var itemType = ViewBag.ItemType == 1 ? "JSON" : "XML";
    var rawContent = ViewBag.RawContent as string;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-eye"></i> Product Details
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">Product Information</h5>
                                </div>
                                <div class="card-body">
                                    <dl class="row mb-0">
                                        <dt class="col-sm-5">
                                            <i class="bi bi-tag"></i> Product Name:
                                        </dt>
                                        <dd class="col-sm-7">
                                            <strong>@Html.DisplayFor(model => model.Name)</strong>
                                        </dd>

                                        <dt class="col-sm-5">
                                            <i class="bi bi-currency-dollar"></i> Price:
                                        </dt>
                                        <dd class="col-sm-7">
                                            <span class="text-success fw-bold fs-5">@Model.Price.ToString("C")</span>
                                        </dd>

                                        <dt class="col-sm-5">
                                            <i class="bi bi-boxes"></i> Stock Quantity:
                                        </dt>
                                        <dd class="col-sm-7">
                                            @if (Model.StockQuantity > 0)
                                            {
                                                <span class="badge bg-success">@Model.StockQuantity units</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Out of stock</span>
                                            }
                                        </dd>

                                        <dt class="col-sm-5">
                                            <i class="bi bi-file-earmark-code"></i> Storage Format:
                                        </dt>
                                        <dd class="col-sm-7">
                                            <span class="badge bg-info">@itemType</span>
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card mb-3">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">Raw Storage Content</h5>
                                </div>
                                <div class="card-body">
                                    <pre class="mb-0 p-3 bg-dark text-light rounded" style="max-height: 300px; overflow-y: auto;"><code>@rawContent</code></pre>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.Name" class="btn btn-warning btn-lg me-2">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Name" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
