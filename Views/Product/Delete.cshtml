@model RepositoryApp.Models.Product

@{
    ViewData["Title"] = "Delete Product";
    var itemType = ViewBag.ItemType == 1 ? "JSON" : "XML";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Delete Product
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this product? This action cannot be undone.
                    </div>

                    <div class="product-details">
                        <h5 class="mb-3">Product Details:</h5>
                        
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <strong><i class="bi bi-tag"></i> Product Name:</strong>
                            </div>
                            <div class="col-md-8">
                                <span class="badge bg-primary fs-6">@Html.DisplayFor(model => model.Name)</span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <strong><i class="bi bi-currency-dollar"></i> Price:</strong>
                            </div>
                            <div class="col-md-8">
                                <span class="text-success fw-bold fs-5">@Model.Price.ToString("C")</span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <strong><i class="bi bi-boxes"></i> Stock Quantity:</strong>
                            </div>
                            <div class="col-md-8">
                                @if (Model.StockQuantity > 0)
                                {
                                    <span class="badge bg-success fs-6">@Model.StockQuantity units in stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Out of stock</span>
                                }
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <strong><i class="bi bi-file-earmark-code"></i> Storage Format:</strong>
                            </div>
                            <div class="col-md-8">
                                <span class="badge bg-info fs-6">@itemType</span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Name" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-between">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> No, Keep It
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Yes, Delete It
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
